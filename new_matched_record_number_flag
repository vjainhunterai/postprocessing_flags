create table  anomaly.`duplicate_ap_invoice`
select * from 
(

WITH grouped_invoice_sets AS (
  SELECT 
    Reason_Grouped,
    Matched_Record_Number,
    GROUP_CONCAT( distinct Supplier_Invoice_Number ORDER BY Supplier_Invoice_Number SEPARATOR ',') AS invoice_combo
  FROM anomaly.`duplicate_ap_invoice`
  GROUP BY Reason_Grouped, Matched_Record_Number
),
group_ranks AS (
  SELECT 
    Reason_Grouped,
    invoice_combo,
    DENSE_RANK() OVER (PARTITION BY Reason_Grouped ORDER BY invoice_combo) AS new_matched_record_number
  FROM (
    SELECT DISTINCT Reason_Grouped, invoice_combo FROM grouped_invoice_sets
  ) AS combos
),
final_with_new_number AS (
  SELECT 
    a.*,
    b.new_matched_record_number
  FROM anomaly.`duplicate_ap_invoice` a
  JOIN grouped_invoice_sets gis
    ON a.Reason_Grouped = gis.Reason_Grouped
   AND a.Matched_Record_Number = gis.Matched_Record_Number
  JOIN group_ranks b
    ON gis.Reason_Grouped = b.Reason_Grouped
   AND gis.invoice_combo = b.invoice_combo
)
SELECT 
  *
FROM final_with_new_number
where Matched_Record_Number <> new_matched_record_number
ORDER BY Reason_Grouped, new_matched_record_number, Supplier_Invoice_Number) a


